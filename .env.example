# Trading Mode
# For Live type live_test

MODE=paper
SIZING_MODE=balance_step

# Risk Controls

STARTING_BALANCE=5
LIVE_MAX_CONTRACTS=10

# Entry Settings

ENTRY_MIN=0.86
ENTRY_MAX=0.94

# Discord

DISCORD_WEBHOOK=

# Logging

ENABLE_LOGS=true
LOG_LEVEL=INFO
